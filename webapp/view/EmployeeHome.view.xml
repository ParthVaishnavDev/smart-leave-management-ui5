<mvc:View
    controllerName="com.parth.smartleavemanagement.controller.EmployeeHome"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page
        id="EmployeeHome"
        title="Employee Home">

        <content>

            <VBox
                class="sapUiLargeMargin"
                alignItems="Center">

                <Title
                    text="Employee Dashboard"
                    level="H2"
                    class="sapUiMediumMarginBottom"/>

                <!-- KPI Tiles -->

                <HBox
                    justifyContent="Center"
                    class="sapUiLargeMarginBottom"
                    width="100%">

                    <GenericTile
                        header="Pending"
                        press="onPendingPress"
                        class="sapUiSmallMargin">

                        <TileContent>
                            <NumericContent
                                value="2"
                                valueColor="Critical"/>
                        </TileContent>

                    </GenericTile>

                    <GenericTile
                        header="Approved"
                        press="onApprovedPress"
                        class="sapUiSmallMargin">

                        <TileContent>
                            <NumericContent
                                value="5"
                                valueColor="Good"/>
                        </TileContent>

                    </GenericTile>

                    <GenericTile
                        header="Rejected"
                        press="onRejectedPress"
                        class="sapUiSmallMargin">

                        <TileContent>
                            <NumericContent
                                value="1"
                                valueColor="Error"/>
                        </TileContent>

                    </GenericTile>

                </HBox>

            

                <Title
                    text="Quick Actions"
                    level="H3"
                    class="sapUiMediumMarginBottom"/>

                <VBox
                    width="280px"
                    alignItems="Stretch">

                    <Button
                        icon="sap-icon://create-entry-time"
                        text="Apply Leave"
                        type="Emphasized"
                        width="100%"
                        press="onApplyLeave"
                        class="sapUiSmallMarginBottom"/>

                    <Button
                        icon="sap-icon://activity-items"
                        text="My Leaves"
                        width="100%"
                        press="onMyLeaves"
                        class="sapUiSmallMarginBottom"/>

                    <Button
                        icon="sap-icon://log"
                        text="Logout"
                        width="100%"
                        type="Reject"
                        press="onLogout"/>

                </VBox>

            </VBox>

        </content>

    </Page>

</mvc:View>